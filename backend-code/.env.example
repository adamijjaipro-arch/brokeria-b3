# ─────────────────────────────────────────────────────────────────────────────
# BrokerIA — Backend Environment Variables
# Copier en .env et remplir les valeurs avant de démarrer
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev) :
DATABASE_URL="file:./dev.db"
# PostgreSQL (prod) — changer aussi provider dans prisma/schema.prisma :
# DATABASE_URL="postgresql://user:password@localhost:5432/brokeria?schema=public"

# ─── Redis (REQUIS pour refresh tokens + magic links) ────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_SUPER_SECRET_ACCESS_KEY_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_SUPER_SECRET_REFRESH_KEY_64_CHARS_MIN_DIFFERENT

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# 1. Aller sur https://github.com/settings/developers
# 2. Créer une "OAuth App"
# 3. Authorization callback URL : http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ─── SMTP (Magic Link + Notifications signaux) ────────────────────────────────
# Gmail : activer "App Password" dans Paramètres > Sécurité > Connexion Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Alternative recommandée en prod : Resend (https://resend.com)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxx

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3006

# ─── Python AI Module ─────────────────────────────────────────────────────────
PYTHON_AI_MODULE_PATH=./ai-module
