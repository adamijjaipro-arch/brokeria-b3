# ─────────────────────────────────────────────────────────────────────────────
# BrokerIA — Backend environment variables
# Copie ce fichier en .env et remplis les valeurs.
# Sur Railway : ajoute chaque variable dans l'onglet "Variables" du service.
# ─────────────────────────────────────────────────────────────────────────────

# ── Serveur ───────────────────────────────────────────────────────────────────
# Railway injecte PORT automatiquement — ne pas modifier
PORT=3000
NODE_ENV=production

# ── Base de données PostgreSQL ────────────────────────────────────────────────
# Railway → Add Service → PostgreSQL → l'URL est générée automatiquement
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway → Add Service → Redis → l'URL est générée automatiquement
REDIS_URL=redis://default:password@host:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Génère des secrets forts avec :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL(s) de ton frontend Vercel (séparées par virgule si plusieurs domaines)
CORS_ORIGINS=https://ton-app.vercel.app

# ── Email SMTP ────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=ton@gmail.com
# Gmail : Paramètres → Sécurité → Mots de passe des applications
SMTP_PASS=

# ── URL frontend (liens dans les emails Magic Link) ───────────────────────────
FRONTEND_URL=https://ton-app.vercel.app

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# github.com/settings/developers → New OAuth App
#   Homepage URL      : https://ton-app.vercel.app
#   Callback URL      : https://ton-backend.railway.app/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://ton-backend.railway.app/auth/github/callback

# ── Module IA (chemin relatif au WORKDIR du container) ───────────────────────
PYTHON_AI_MODULE_PATH=./ai-module
