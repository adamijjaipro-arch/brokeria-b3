DATABASE_URL="postgresql://brokeria_test:test_password@localhost:5433/brokeria_test"
REDIS_URL="redis://localhost:6380"
JWT_SECRET="test-secret"
JWT_REFRESH_SECRET="test-refresh-secret"
NODE_ENV="test"
# GithubStrategy (passport-oauth2) lève une exception à la construction si
# clientID est vide — même si on ne teste jamais le flux GitHub ici, il faut
# des valeurs non-vides pour que le module Nest se compile. Ne pas dépendre
# du .env local (gitignoré, absent en CI) pour ça.
GITHUB_CLIENT_ID="test-github-client-id"
GITHUB_CLIENT_SECRET="test-github-client-secret"
GITHUB_CALLBACK_URL="http://localhost:3001/auth/github/callback"
