{
  "title": "BrokerIA — MFA & Security Dashboard",
  "uid": "brokeria-mfa-security",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [

    { "id": 1, "type": "stat", "title": "Auth Attempts (total)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(auth_attempts_total{app=\"brokeria\"})", "legendFormat": "Total" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } } },

    { "id": 2, "type": "stat", "title": "Taux de Succès Auth (%)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(auth_attempts_total{result=\"success\"}) / sum(auth_attempts_total) * 100", "legendFormat": "%" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 80 }, { "color": "green", "value": 95 }] } } } },

    { "id": 3, "type": "stat", "title": "Sessions Actives",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "active_sessions_total{app=\"brokeria\"}", "legendFormat": "Sessions" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } } },

    { "id": 4, "type": "stat", "title": "Comptes Verrouillés",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "account_locks_total{app=\"brokeria\"}", "legendFormat": "Locks" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } } } },

    { "id": 11, "type": "stat", "title": "IPs Suspectes (total)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(auth_attempts_total{app=\"brokeria\",result=\"suspicious_ip\"}) or vector(0)", "legendFormat": "IPs" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] } } } },

    { "id": 12, "type": "stat", "title": "Erreurs 5xx",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(http_errors_5xx_total{app=\"brokeria\"})", "legendFormat": "5xx" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] } } } },

    { "id": 5, "type": "timeseries", "title": "Tentatives Auth par Facteur (rate/5m)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by(factor) (rate(auth_attempts_total{app=\"brokeria\"}[5m]))", "legendFormat": "{{factor}}" }],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } } },

    { "id": 6, "type": "timeseries", "title": "Succès vs Échecs Auth (rate/5m)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by(result) (rate(auth_attempts_total{app=\"brokeria\"}[5m]))", "legendFormat": "{{result}}" }],
      "fieldConfig": { "overrides": [
        { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
      ] } },

    { "id": 7, "type": "timeseries", "title": "Latence Auth p95 par Facteur",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by(le, factor) (rate(auth_latency_seconds_bucket{app=\"brokeria\"}[5m])))", "legendFormat": "p95 {{factor}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } } },

    { "id": 8, "type": "timeseries", "title": "Enrôlements MFA (enroll / revoke)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by(factor, action) (rate(mfa_enrollments_total{app=\"brokeria\"}[5m]))", "legendFormat": "{{factor}} / {{action}}" }] },

    { "id": 13, "type": "timeseries", "title": "Verrouillages de Compte (brute-force)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "targets": [{ "expr": "rate(account_locks_total{app=\"brokeria\"}[5m])", "legendFormat": "Locks/s" }],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" },
        "custom": { "lineWidth": 2, "fillOpacity": 20 } } } },

    { "id": 9, "type": "timeseries", "title": "Erreurs HTTP 5xx (rate/5m)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "targets": [{ "expr": "sum(rate(http_errors_5xx_total{app=\"brokeria\"}[5m]))", "legendFormat": "5xx/s" }],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } } },

    { "id": 14, "type": "piechart", "title": "Répartition Auth par Facteur MFA",
      "gridPos": { "x": 0, "y": 26, "w": 8, "h": 8 },
      "targets": [{ "expr": "sum by(factor) (auth_attempts_total{app=\"brokeria\",result=\"success\"})", "legendFormat": "{{factor}}" }],
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"] } },

    { "id": 15, "type": "piechart", "title": "Enrôlements MFA actifs par Type",
      "gridPos": { "x": 8, "y": 26, "w": 8, "h": 8 },
      "targets": [{ "expr": "sum by(factor) (mfa_enrollments_total{app=\"brokeria\",action=\"enroll\"}) - sum by(factor) (mfa_enrollments_total{app=\"brokeria\",action=\"revoke\"} or vector(0))", "legendFormat": "{{factor}}" }],
      "options": { "pieType": "pie", "displayLabels": ["name", "value"] } },

    { "id": 16, "type": "timeseries", "title": "Sessions Créées / Expirées",
      "gridPos": { "x": 16, "y": 26, "w": 8, "h": 8 },
      "targets": [
        { "expr": "rate(auth_attempts_total{app=\"brokeria\",event_type=\"SESSION_CREATED\"}[5m]) or vector(0)", "legendFormat": "Créées" },
        { "expr": "rate(auth_attempts_total{app=\"brokeria\",event_type=\"SESSION_EXPIRED\"}[5m]) or vector(0)", "legendFormat": "Expirées" }
      ],
      "fieldConfig": { "overrides": [
        { "matcher": { "id": "byName", "options": "Créées" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "Expirées" }, "properties": [{ "id": "color", "value": { "fixedColor": "grey", "mode": "fixed" } }] }
      ] } },

    { "id": 17, "type": "timeseries", "title": "Détection Brute-Force — Échecs consécutifs (rate/1m)",
      "description": "Pic → tentative de brute-force en cours. Alerte si > seuil configuré.",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 7 },
      "targets": [
        { "expr": "sum by(factor) (rate(auth_attempts_total{app=\"brokeria\",result=\"failure\"}[1m]))", "legendFormat": "échecs {{factor}} /min" }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15 },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] },
        "custom2": { "thresholdsStyle": { "mode": "line+area" } } } },
      "alert": {
        "name": "Brute-Force Détecté",
        "conditions": [{ "evaluator": { "params": [0.5], "type": "gt" }, "operator": { "type": "and" },
          "query": { "params": ["A", "1m", "now"] }, "reducer": { "params": [], "type": "max" }, "type": "query" }],
        "executionErrorState": "alerting", "frequency": "1m", "handler": 1, "noDataState": "no_data"
      } }
  ]
}
