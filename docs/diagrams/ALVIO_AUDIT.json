    "conc-03": {
      "title": "Flux authentification complet",
      "files": [
        "backend-code/src/auth/auth.service.ts",
        "backend-code/src/auth/auth.controller.ts",
        "backend-code/src/mfa/totp/totp.service.ts",
        "backend-code/src/mfa/webauthn/webauthn.service.ts",
        "backend-code/src/redis/redis.service.ts"
      ],
      "flow_steps": [
        "POST /auth/register → hash bcrypt → preAuthToken Redis 10min",
        "POST /auth/login → verify password → preAuthToken Redis 10min",
        "POST /auth/2fa/verify → TOTP/OTP email → pinAuthToken ou JWT final",
        "POST /auth/pin/verify → PIN → accessToken 15min + refresh cookie 7j",
        "POST /auth/refresh → rotate refresh Redis → nouveau accessToken",
        "GET /auth/github → GitHub OAuth → POST /auth/github/callback",
        "POST /auth/magic-link/request → email SMTP → token Redis 15min",
        "POST /auth/magic-link/verify → JWT final"
      ],
      "tasks": [
        "Diagramme séquence auth email/password + MFA",
        "Diagramme séquence GitHub OAuth",
        "Diagramme séquence magic link"
      ]
    }
  },

