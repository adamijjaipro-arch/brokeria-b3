  "conception": {
    "conc-01": {
      "title": "Architecture générale Alvio",
      "files": [
        "backend-code/src/main.ts",
        "backend-code/src/app.module.ts",
        "docker-compose.yml",
        "backend-code/prisma/schema.prisma"
      ],
      "decisions": [
        "Global prefix: /api (implicite via routes)",
        "Global guard: JwtAuthGuard ou JwtGuard selon module",
        "Response wrapping: TransformInterceptor → { data: T }",
        "Error format: HttpExceptionFilter → { statusCode, timestamp, message }",
        "Cookie Parser: requis pour refresh_token httpOnly",
        "ValidationPipe: transform enabled",
        "CORS origins: localhost:3000, localhost:3006"
      ],
      "tasks": [
        "Diagramme architecture C4 Level 2",
        "Valider stack docker-compose (postgres + redis)",
        "Documenter flux inter-modules"
      ]
