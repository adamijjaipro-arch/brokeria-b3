        "routes_count": 14,
        "controller_routes": [
          "POST   /auth/register          → register()          [public]",
          "POST   /auth/login             → login()             [public]",
          "POST   /auth/magic-link/request→ requestMagicLink()  [public]",
          "POST   /auth/magic-link/verify → verifyMagicLink()   [public]",
          "GET    /auth/github            → githubLogin()       [AuthGuard('github')]",
          "GET    /auth/github/callback   → githubCallback()    [AuthGuard('github')]",
          "POST   /auth/2fa/verify        → verify2FA()         [public]",
          "POST   /auth/pin/verify        → verifyPin()         [public]",
          "POST   /auth/pin/setup         → setupPin()          [public]",
          "POST   /auth/set-password      → setPassword()       [public]",
          "POST   /auth/refresh           → refresh()           [public]",
          "POST   /auth/logout            → logout()            [public]",
          "POST   /auth/dev-login         → devLogin()          [public]",
          "GET    /auth/profile           → getProfile()        [JwtAuthGuard]"
        ],
        "mfa_totp_routes": [
          "GET    /mfa/totp/status        → getStatus()         [JwtAuthGuard]",
          "POST   /mfa/totp/enroll/init   → enrollInit()        [JwtAuthGuard]",
          "POST   /mfa/totp/enroll/confirm→ enrollConfirm()     [JwtAuthGuard]",
          "POST   /mfa/totp/verify        → verify()            [JwtAuthGuard]",
          "POST   /mfa/totp/disable       → disable()           [JwtAuthGuard]"
        ],
        "mfa_webauthn_routes": [
          "GET    /mfa/webauthn/credentials        → listCredentials()       [JwtAuthGuard]",
          "POST   /mfa/webauthn/register/options   → registrationOptions()   [JwtAuthGuard]",
          "POST   /mfa/webauthn/register/verify    → registrationVerify()    [JwtAuthGuard]",
          "POST   /mfa/webauthn/auth/options       → authenticationOptions() [JwtAuthGuard]",
          "POST   /mfa/webauthn/auth/verify        → authenticationVerify()  [JwtAuthGuard]",
          "DELETE /mfa/webauthn/credentials/:id    → removeCredential()      [JwtAuthGuard]"
        ],
        "dto_classes": [
          "RegisterDto:      { email, username, password (min 6) }",
          "LoginDto:         { email, password }",
          "Verify2FADto:     { preAuthToken, otp }",
          "VerifyPinDto:     { pinAuthToken, pin }",
          "SetupPinDto:      { pinAuthToken, pin }",
          "SetPasswordDto:   { preAuthToken, password }",
          "MagicLinkDto:     { email | token }",
          "VerifyTotpDto:    { code (6 digits exactly) }",
          "DisableTotpDto:   { code (6 digits exactly) }"
        ],
        "redis_keys": [
          "pre_auth:{token}    → userId | TTL 10min",
          "pin_auth:{token}    → userId | TTL 10min",
          "magic:{token}       → email  | TTL 15min",
          "refresh:{jti}       → userId | TTL 7 jours",
          "lockout:{userId}    → count  | TTL LOCK_TTL_SECONDS",
          "ip_fail:{ip}        → count  | TTL configurable"
        ],
