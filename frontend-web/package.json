{
  "name": "alvio-frontend",
  "version": "1.0.0",
  "description": "Next.js frontend for Alvio — AI trading platform",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^10.0.0",
    "autoprefixer": "^10.4.14",
    "axios": "^1.4.0",
    "framer-motion": "^12.34.1",
    "lightweight-charts": "^4.2.3",
    "next": "13.4.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.24",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "^3.3.0",
    "typescript": "5.1.3",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "20.3.1",
    "@types/react": "18.2.6",
    "@types/react-dom": "18.2.4",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "@vitest/ui": "^4.1.0",
    "eslint": "8.42.0",
    "eslint-config-next": "13.4.0",
    "eslint-config-prettier": "^10.1.8",
