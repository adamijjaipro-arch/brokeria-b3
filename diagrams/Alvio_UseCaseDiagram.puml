@startuml Alvio_UseCaseDiagram
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #0f0f23
skinparam ArrowColor #7c6af7
skinparam ActorBorderColor #7c6af7
skinparam ActorFontColor #e2e8f0
skinparam UsecaseBorderColor #7c6af7
skinparam UsecaseBackgroundColor #1a1a3e
skinparam UsecaseFontColor #e2e8f0
skinparam PackageBorderColor #2d2d5e
skinparam PackageBackgroundColor #12122a
skinparam PackageFontColor #a78bfa

' ==================== ACTEURS ====================
actor "Visiteur" as Visitor
actor "Trader\n(User authentifié)" as Trader
actor "Admin / DevOps" as Admin
actor "Scheduler\n(Système)" as Scheduler
actor "Module Python IA" as PythonAI
actor "CoinGecko API" as CoinGecko
actor "Anthropic\nClaude API" as ClaudeAPI
actor "Serveur SMTP" as SMTP
actor "Prometheus" as Prometheus
actor "Syslog UDP" as Syslog

Visitor <|-- Trader
Trader <|-- Admin

' ==================== AUTH ====================
package "Authentification" {
    usecase "S'inscrire" as UC_A01
    usecase "Se connecter\n(email/password)" as UC_A02
    usecase "Se connecter\nvia GitHub OAuth" as UC_A03
    usecase "Demander un\nmagic link" as UC_A04
    usecase "Vérifier\nmagic link" as UC_A05
    usecase "Vérifier OTP\nemail (2FA)" as UC_A06
    usecase "Vérifier PIN" as UC_A07
    usecase "Configurer PIN" as UC_A08
    usecase "Définir mot\nde passe" as UC_A09
    usecase "Rafraîchir\ntoken JWT" as UC_A10
    usecase "Se déconnecter" as UC_A11
    usecase "Consulter\nson profil" as UC_A12
    usecase "Émettre tokens\nJWT (interne)" as UC_IssueTokens
}

Visitor --> UC_A01
Visitor --> UC_A02
Visitor --> UC_A03
Visitor --> UC_A04
Visitor --> UC_A05
Trader --> UC_A06
Trader --> UC_A07
Trader --> UC_A08
Trader --> UC_A09
Trader --> UC_A10
Trader --> UC_A11
Trader --> UC_A12

UC_A02 ..> UC_IssueTokens : <<include>>
UC_A04 ..> SMTP : <<include>>
UC_A06 ..> SMTP : <<include>>
UC_A10 ..> UC_IssueTokens : <<include>>
UC_A02 ..> UC_A06 : <<extend>>\n[si MFA actif]
UC_A06 ..> UC_A08 : <<extend>>\n[si PIN non défini]
UC_A06 ..> UC_A07 : <<extend>>\n[si PIN défini]
UC_A03 ..> UC_A09 : <<extend>>\n[si nouveau compte OAuth]

' ==================== MFA ====================
package "MFA — TOTP & WebAuthn" {
    usecase "Vérifier statut TOTP" as UC_T01
    usecase "Initier enrollment TOTP\n(QR code AES-256-GCM)" as UC_T02
    usecase "Confirmer enrollment TOTP" as UC_T03
    usecase "Vérifier code TOTP" as UC_T04
    usecase "Désactiver TOTP" as UC_T05

    usecase "Lister credentials\nWebAuthn" as UC_W01
    usecase "Enregistrer passkey\n(options)" as UC_W02
    usecase "Vérifier enregistrement\npasskey" as UC_W03
    usecase "Authentifier passkey\n(options)" as UC_W04
    usecase "Vérifier authentification\npasskey" as UC_W05
    usecase "Supprimer credential\nWebAuthn" as UC_W06
}

Trader --> UC_T01
Trader --> UC_T02
Trader --> UC_T03
Trader --> UC_T04
Trader --> UC_T05
Trader --> UC_W01
Trader --> UC_W02
Trader --> UC_W03
Trader --> UC_W04
Trader --> UC_W05
Trader --> UC_W06

' ==================== SIGNALS ====================
package "Signaux de Trading" {
    usecase "Consulter ses signaux" as UC_S01
    usecase "Consulter signaux récents" as UC_S02
    usecase "Créer signal manuellement" as UC_S03
    usecase "Générer signal (IA)" as UC_S04
    usecase "Consulter statistiques\nsignaux" as UC_S05
    usecase "Lancer scan manuel" as UC_S06
    usecase "Scan automatique\npériodique (Cron)" as UC_S07
    usecase "Notifier utilisateurs\npar email" as UC_S08
}

Trader --> UC_S01
Trader --> UC_S02
Trader --> UC_S03
Trader --> UC_S04
Trader --> UC_S05
Trader --> UC_S06
Scheduler --> UC_S07

UC_S07 ..> UC_S04 : <<include>>
UC_S04 ..> UC_S08 : <<extend>>\n[si notifications activées]
UC_S07 ..> UC_S08 : <<extend>>\n[si signal généré]
UC_S08 ..> SMTP : <<include>>

' ==================== STRATEGIES ====================
package "Stratégies" {
    usecase "Consulter ses stratégies" as UC_ST01
    usecase "Analyser une stratégie" as UC_ST02
    usecase "Importer stratégie\n(PDF / document)" as UC_ST03
}

Trader --> UC_ST01
Trader --> UC_ST02
Trader --> UC_ST03
UC_ST03 ..> ClaudeAPI : <<include>>
UC_ST02 ..> ClaudeAPI : <<include>>

' ==================== PATTERNS ====================
package "Détection de Patterns (Python)" {
    usecase "Détecter patterns\n(endpoint)" as UC_P01
    usecase "Calculer indicateurs\ntechniques" as UC_P02
    usecase "Patterns chartistes\n(Double Top/Bottom, HnS)" as UC_P03
    usecase "Patterns chandeliers\n(Hammer, Doji, Engulfing)" as UC_P04
    usecase "Patterns harmoniques\n(Gartley, Bat, Crab)" as UC_P05
    usecase "Vagues d'Elliott" as UC_P06
    usecase "Calculer Ichimoku" as UC_P07
    usecase "Scorer le signal\n(ScoringEngine)" as UC_P08
}

Trader --> UC_P01
PythonAI --> UC_P02
PythonAI --> UC_P03
PythonAI --> UC_P04
PythonAI --> UC_P05
PythonAI --> UC_P06
PythonAI --> UC_P07
PythonAI --> UC_P08

UC_P01 ..> UC_P02 : <<include>>
UC_P01 ..> UC_P03 : <<include>>
UC_P01 ..> UC_P04 : <<include>>
UC_P01 ..> UC_P08 : <<include>>
UC_P05 ..> UC_P01 : <<extend>>
UC_P06 ..> UC_P01 : <<extend>>
UC_P07 ..> UC_P01 : <<extend>>
UC_S04 ..> UC_P01 : <<include>>

' ==================== MARKETS ====================
package "Données de Marché" {
    usecase "Consulter top 20 crypto\n(cache 60s)" as UC_M01
    usecase "Consulter détail crypto\n(cache 30s)" as UC_M02
    usecase "Consulter OHLCV\n(candles / line)" as UC_M03
}

Trader --> UC_M01
Trader --> UC_M02
Trader --> UC_M03

UC_M01 ..> CoinGecko : <<extend>>\n[cache miss]
UC_M02 ..> CoinGecko : <<extend>>\n[cache miss]
UC_M03 ..> CoinGecko : <<extend>>\n[cache miss]
UC_P01 ..> UC_M03 : <<include>>

' ==================== PORTFOLIO ====================
package "Portfolio" {
    usecase "Consulter historique\nportfolio" as UC_PO01
    usecase "Consulter statistiques\nportfolio" as UC_PO02
    usecase "Snapshot mensuel\nautomatique (Cron)" as UC_PO03
}

Trader --> UC_PO01
Trader --> UC_PO02
Scheduler --> UC_PO03

' ==================== SIMULATOR ====================
package "Simulateur DCA" {
    usecase "Simuler un DCA\n(Monte Carlo)" as UC_SI01
    usecase "Consulter historique\nsimulations" as UC_SI02
}

Trader --> UC_SI01
Trader --> UC_SI02

' ==================== FORMATION ====================
package "Formation" {
    usecase "Consulter les cours" as UC_F01
    usecase "Consulter détail cours" as UC_F02
    usecase "Consulter une leçon" as UC_F03
    usecase "Marquer leçon complète" as UC_F04
    usecase "Consulter progression\nglobale" as UC_F05
}

Trader --> UC_F01
Trader --> UC_F02
Trader --> UC_F03
Trader --> UC_F04
Trader --> UC_F05

' ==================== REPORTS ====================
package "Rapports" {
    usecase "Consulter statistiques\nmensuelles" as UC_R01
}
Trader --> UC_R01

' ==================== SECURITY ====================
package "Sécurité & Observabilité" {
    usecase "Journaliser événement\nde sécurité" as UC_SE01
    usecase "Mettre à jour\nmétriques Prometheus" as UC_SE02
    usecase "Verrouiller un compte\n(lockout Redis)" as UC_SE03
    usecase "Détecter IP suspecte" as UC_SE04
    usecase "Consulter métriques\n/metrics (IP whitelist)" as UC_SE05
}

Scheduler --> UC_SE01
Admin --> UC_SE05
Prometheus --> UC_SE05

UC_SE01 ..> UC_SE02 : <<include>>
UC_SE01 ..> Syslog : <<include>>
UC_SE01 ..> UC_SE03 : <<extend>>\n[si maxFailures atteint]
UC_SE01 ..> UC_SE04 : <<extend>>\n[si maxIpFailures atteint]
UC_SE02 ..> Prometheus : <<include>>

@enduml
